{
  "assistant_name": "Jarvis",
  "voice_input_enabled": true,
  "voice_output_enabled": true,
  "dangerous_system_actions_enabled": true,
  "wake_word_enabled": false,
  "wake_word": "jarvis",
  "vosk_model_path": "",
